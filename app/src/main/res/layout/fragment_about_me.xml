<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Blue header with avatar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:padding="20dp"
            android:paddingBottom="36dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:id="@+id/header_row">
                <ImageButton android:id="@+id/btn_back"
                    android:layout_width="36dp" android:layout_height="36dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@drawable/bg_header_icon_btn"
                    android:padding="6dp" android:layout_marginEnd="12dp"
                    android:contentDescription="Back" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="About Me" android:textSize="20sp" android:textStyle="bold"
                    android:textColor="@color/white" />
            </LinearLayout>

            <!-- Avatar circle -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_below="@id/header_row"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle">

                <ImageView android:layout_width="40dp" android:layout_height="40dp"
                    android:src="@drawable/ic_person" app:tint="@color/white" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_profile_name_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/header_row"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="104dp"
                android:text="Your Name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:id="@+id/tv_diabetes_type_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tv_profile_name_header"
                android:layout_centerHorizontal="true"
                android:text="Type 2 Diabetes"
                android:textSize="12sp"
                android:textColor="#B3E5FC"
                android:layout_marginTop="2dp" />
        </RelativeLayout>

        <!-- Profile info card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginTop="-20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Personal Information" style="@style/TextSectionHeader"
                    android:layout_marginBottom="16dp" />

                <!-- Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_name"
                    style="@style/TextInputStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:hint="Full Name"
                    app:startIconDrawable="@drawable/ic_person">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapWords"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Age -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_age"
                    style="@style/TextInputStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:hint="Age"
                    app:startIconDrawable="@drawable/ic_calendar">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_age"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" android:maxLength="3"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Diagnosis year -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_diagnosis_year"
                    style="@style/TextInputStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" android:hint="Year of Diagnosis"
                    app:startIconDrawable="@drawable/ic_calendar">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_diagnosis_year"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" android:maxLength="4"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Doctor -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_doctor"
                    style="@style/TextInputStyle"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" android:hint="Doctor's Name"
                    app:startIconDrawable="@drawable/ic_doctor">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_doctor"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapWords"
                        android:textColor="@color/text_primary" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Diabetes type chips -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Diabetes Type" android:textSize="13sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="6dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_diabetes_type"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:singleSelection="true" app:selectionRequired="true">

                    <com.google.android.material.chip.Chip android:id="@+id/chip_type1"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Type 1" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_type2"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Type 2" android:checked="true" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_gestational"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gestational" />
                    <com.google.android.material.chip.Chip android:id="@+id/chip_prediabetes"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Pre-diabetes" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_profile"
                    style="@style/ButtonPrimary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Save Profile" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Reminders card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Reminders &amp; Alerts" style="@style/TextSectionHeader"
                    android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Daily Lifestyle Reminders"
                        android:textSize="14sp" android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_glucose_reminder"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Medication Reminders"
                        android:textSize="14sp" android:textColor="@color/text_primary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_med_reminder"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_test_reminder"
                    style="@style/ButtonOutlined"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Test Reminder Now"
                    app:icon="@drawable/ic_reminder" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Language card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Language / ಭಾಷೆ" style="@style/TextSectionHeader"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_language"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:singleSelection="true" app:selectionRequired="true">

                    <com.google.android.material.chip.Chip android:id="@+id/chip_en"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="English" android:checked="true" />

                    <com.google.android.material.chip.Chip android:id="@+id/chip_kn"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ಕನ್ನಡ (Kannada)" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Sign Out"
                    app:backgroundTint="@color/error"
                    style="@style/ButtonPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Developer info card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/CardStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="32dp"
            app:cardBackgroundColor="#F3E5F5">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/app_name" android:textSize="18sp" android:textStyle="bold"
                    android:textColor="@color/primary" android:layout_marginBottom="2dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/app_version" android:textSize="11sp"
                    android:textColor="@color/text_secondary" android:layout_marginBottom="16dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/developed_by" android:textSize="11sp"
                    android:textColor="@color/text_secondary" android:textAllCaps="true"
                    android:letterSpacing="0.08" android:layout_marginBottom="4dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/developer_name" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/developer_designation"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
