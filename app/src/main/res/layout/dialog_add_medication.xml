<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <!-- Name -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/TextInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Medication Name"
            android:layout_marginBottom="10dp"
            app:startIconDrawable="@drawable/ic_medication">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_med_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dose -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/TextInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dose (e.g. 500mg, 1 tablet)"
            android:layout_marginBottom="12dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_med_dose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medication type"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_med_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_tablet"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="Tablet" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_insulin"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insulin" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_injection"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Injection" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_syrup"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Syrup" />
        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/TextInputStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Start Date"
            app:startIconDrawable="@drawable/ic_calendar">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_start_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:textColor="@color/text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Frequency -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Frequency"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_frequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_od"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OD x1"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_bd"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BD x2" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_tid"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TID x3" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_qid"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="QID x4" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Meal timing -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="When to take"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="6dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_meal_timing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_before_food"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Before Meal"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_after_food"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="After Meal" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_with_food"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="With Meal" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Reminder times -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reminder Times (tap to change)"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Time 1 (always visible) -->
        <LinearLayout
            android:id="@+id/row_time1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Dose 1:"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_time1"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                app:icon="@drawable/ic_clock"
                app:iconSize="14dp" />
        </LinearLayout>

        <!-- Time 2 (BD, TID, QID) -->
        <LinearLayout
            android:id="@+id/row_time2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Dose 2:"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_time2"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20:00"
                app:icon="@drawable/ic_clock"
                app:iconSize="14dp" />
        </LinearLayout>

        <!-- Time 3 (TID, QID) -->
        <LinearLayout
            android:id="@+id/row_time3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Dose 3:"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_time3"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:00"
                app:icon="@drawable/ic_clock"
                app:iconSize="14dp" />
        </LinearLayout>

        <!-- Time 4 (QID only) -->
        <LinearLayout
            android:id="@+id/row_time4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">
            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Dose 4:"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_time4"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21:00"
                app:icon="@drawable/ic_clock"
                app:iconSize="14dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
