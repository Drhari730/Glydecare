<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="18dp"
                android:text="Glucose level"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- Range period toggle -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_period"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:tabMode="fixed"
                app:tabBackground="@color/surface"
                app:tabSelectedTextColor="@color/white"
                app:tabIndicatorColor="@color/health_teal"
                app:tabRippleColor="@color/primary_light">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/seven_days" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/thirty_days" />
            </com.google.android.material.tabs.TabLayout>

            <!-- Trend chart card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/CardStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Glucose Trend"
                        style="@style/TextSectionHeader"
                        android:layout_marginBottom="8dp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/glucose_chart"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_height" />

                    <!-- Legend -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="8dp">

                        <View android:layout_width="12dp" android:layout_height="3dp"
                            android:background="@color/glucose_low" android:layout_marginEnd="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/low_label" android:textSize="10sp"
                            android:textColor="@color/glucose_low" android:layout_marginEnd="12dp" />

                        <View android:layout_width="12dp" android:layout_height="3dp"
                            android:background="@color/glucose_normal" android:layout_marginEnd="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/normal_label" android:textSize="10sp"
                            android:textColor="@color/glucose_normal" android:layout_marginEnd="12dp" />

                        <View android:layout_width="12dp" android:layout_height="3dp"
                            android:background="@color/glucose_high" android:layout_marginEnd="4dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/high_label" android:textSize="10sp"
                            android:textColor="@color/glucose_high" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    style="@style/CardStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:gravity="center">
                        <TextView android:id="@+id/tv_avg_glucose" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textSize="20sp" android:textStyle="bold" android:textColor="@color/primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg mg/dL" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/CardStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:gravity="center">
                        <TextView android:id="@+id/tv_readings_count" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="20sp" android:textStyle="bold" android:textColor="@color/secondary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Readings" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/CardStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="12dp" android:gravity="center">
                        <TextView android:id="@+id/tv_out_of_range" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0"
                            android:textSize="20sp" android:textStyle="bold" android:textColor="@color/error" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Out of range" android:textSize="11sp" android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- History list header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Readings"
                style="@style/TextSectionHeader"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_glucose_readings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

    <!-- FAB to add reading -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_add_glucose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/fab_margin"
        android:text="@string/add_reading"
        app:icon="@drawable/ic_add"
        app:backgroundTint="@color/primary"
        android:textColor="@color/white"
        app:iconTint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
